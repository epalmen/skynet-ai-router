# ---------------------------------------------------------------
# Skynet AI Router — environment configuration
# Copy this file to .env and adjust values for your setup.
# ---------------------------------------------------------------

# Backend to use when the caller doesn't specify one.
# Options: local | claude
DEFAULT_BACKEND=local

# Ollama settings
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Claude CLI model (must match a model available on your Pro subscription)
CLAUDE_MODEL=claude-sonnet-4-6

# Router bind address and port
ROUTER_HOST=0.0.0.0
ROUTER_PORT=3000
